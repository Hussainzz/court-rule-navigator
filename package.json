{
  "name": "court-rule-navigator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --incremental false",
    "check": "pnpm typecheck && pnpm lint && pnpm build",
    "inspect:pdf": "tsx scripts/inspect-pdf.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "tsx scripts/check-db.ts",
    "source:check": "tsx scripts/check-source-manifest.ts",
    "source:extract-check": "tsx scripts/check-pdf-extraction.ts",
    "source:inspect-headers": "tsx scripts/inspect-page-headers.ts",
    "source:label-check": "tsx scripts/check-page-labels.ts",
    "source:ingest": "tsx scripts/ingest-source-document.ts",
    "rules:inspect-headings": "tsx scripts/inspect-rule-headings.ts",
    "rules:parse-check": "tsx scripts/check-rule-parser.ts",
    "chunks:check": "tsx scripts/check-rule-chunks.ts",
    "embeddings:text-check": "tsx scripts/check-embedding-text.ts",
